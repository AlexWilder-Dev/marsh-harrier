# Required — staff dashboard password
ADMIN_PASSWORD=change-me-to-something-secure

# Turso database (required in production — get from turso.tech)
# Leave unset locally to use a local SQLite file at ./data/ordering.db
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# Room booking form — create a free account at formspree.io, then paste your form ID here
# NEXT_PUBLIC_FORMSPREE_ID=your-form-id
